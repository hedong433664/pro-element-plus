{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": [
      "./vite-env.d.ts",
      "@coderhd/pro-element-plus/global"
    ],
    "paths": {
      "@/*": [
        "./.vitepress/theme/*"
      ]
    },
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "erasableSyntaxOnly": true
  },
  "include": [
    ".vitepress/theme/**/*.ts",
    ".vitepress/theme/**/*.tsx",
    ".vitepress/theme/**/*.vue",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.vue",
    "vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".vitepress/cache",
    ".vitepress/dist"
  ]
}