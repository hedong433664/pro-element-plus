{
  "name": "@coderhd/pro-element-plus",
  "version": "2.0.0",
  "description": "基于 Element Plus 的二次封装 Vue 3 组件库",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/css/index.css",
    "./es/*": {
      "types": "./dist/es/*/index.d.ts",
      "import": "./dist/es/*/index.mjs"
    },
    "./lib/*": {
      "types": "./dist/es/*/index.d.ts",
      "require": "./dist/lib/*/index.js"
    },
    "./es/*/style": {
      "types": "./dist/es/*/style/index.d.ts",
      "import": "./dist/es/*/style/index.mjs"
    },
    "./es/*/style/css": {
      "types": "./dist/es/*/style/css.d.ts",
      "import": "./dist/es/*/style/css.mjs"
    },
    "./lib/*/style": {
      "types": "./dist/es/*/style/index.d.ts",
      "require": "./dist/lib/*/style/index.js"
    },
    "./lib/*/style/css": {
      "types": "./dist/es/*/style/css.d.ts",
      "require": "./dist/lib/*/style/css.js"
    },
    "./global": {
      "types": "./global.d.ts"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.mjs"
    }
  },
  "sideEffects": [
    "**/*.css",
    "**/*.vue",
    "**/style/**"
  ],
  "files": [
    "dist",
    "global.d.ts"
  ],
  "scripts": {
    "build": "rimraf dist && vite build --config vite.es.config.ts && vite build --config vite.lib.config.ts && vite build --config vite.index.config.ts && node scripts/build-css.mjs && node scripts/build-style-entries.mjs && node scripts/finalize-dist.mjs && pnpm run build:resolver",
    "build:resolver": "pnpm exec esbuild resolver.ts --bundle --format=esm --platform=neutral --outfile=dist/resolver.mjs && pnpm exec tsc resolver.ts --declaration --emitDeclarationOnly --outDir dist --module ESNext --moduleResolution Bundler --target ES2022 --skipLibCheck",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "element-plus",
    "components"
  ],
  "license": "ISC",
  "packageManager": "pnpm@10.6.5",
  "peerDependencies": {
    "element-plus": "^2.7.0",
    "lodash-es": "^4.17.21",
    "vue": "^3.4.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^6.0.5",
    "element-plus": "^2.13.5",
    "lodash-es": "^4.17.23",
    "esbuild": "^0.27.4",
    "rimraf": "^6.0.1",
    "sass": "^1.98.0",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
